# ───── 認証モード（統一SSO）─────
# このアプリは bound（SSO受信）固定。認証はハブ（digicollabo.com）のみが行う
VITE_AUTH_MODE=bound
VITE_AUTH_HUB_URL=https://digicollabo.com

# ───── Supabase ─────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ───── デプロイ先 ─────
VITE_APP_URL=https://cart.digicollabo.com

# ───── Page renderer（tpl-checkout / purchase-complete の配置先）─────
VITE_PAGE_RENDERER_URL=https://page.digicollabo.com

# ───── データモード（常に supabase、standalone は廃止）─────
VITE_DATA_MODE=supabase
